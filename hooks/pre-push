#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import subprocess
import sys
import os
import re

BASE_DIR = subprocess.run(
    ['git', 'rev-parse', '--show-toplevel'], capture_output=True, text=True, check=True
).stdout.strip()

def run_command(cmd, cwd=None):
    if cwd is None:
        cwd = BASE_DIR
    result = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)
    return result.stdout, result.stderr, result.returncode

def main():
    print("=" * 50)
    print("  Git Pre-Push Hook - 推送前检查")
    print("=" * 50)
    
    print("\n1. 检查当前分支...")
    stdout, stderr, rc = run_command(['git', 'rev-parse', '--abbrev-ref', 'HEAD'])
    current_branch = stdout.strip()
    print(f"   当前分支: {current_branch}")
    
    protected_branches = ['master', 'main', 'develop']
    if current_branch in protected_branches:
        print(f"   ✗ 禁止直接推送到保护分支: {current_branch}")
        print("   ✗ 请通过PR提交")
        sys.exit(1)
    
    print("\n2. 检查提交数量...")
    stdout, stderr, rc = run_command(['git', 'rev-list', '--count', f'HEAD..origin/{current_branch}'])
    try:
        commits_ahead = int(stdout.strip()) if stdout.strip() else 0
    except:
        commits_ahead = 0
    
    if commits_ahead > 0:
        print("   ✗ 远程分支有新提交，请先拉取更新")
        print(f"   ✗ 执行: git pull origin {current_branch}")
        sys.exit(1)
    print("   ✓ 提交数量检查通过")
    
    print("\n3. 执行数据资产一致性校验...")
    stdout, stderr, rc = run_command([sys.executable, 'scripts/validate_consistency.py'])
    if rc != 0:
        print("   ✗ 数据资产一致性校验失败")
        print("   ✗ 请修复校验错误后重新推送")
        sys.exit(1)
    print("   ✓ 数据资产一致性校验通过")
    
    print("\n4. 执行文件生成校验...")
    stdout, stderr, rc = run_command([sys.executable, 'scripts/validate_generated_files.py'])
    if rc != 0:
        print("   ✗ 文件生成校验失败")
        print("   ✗ 请修复校验错误后重新推送")
        sys.exit(1)
    print("   ✓ 文件生成校验通过")
    
    print("\n" + "=" * 50)
    print("  所有检查通过，可以推送!")
    print("=" * 50)
    
    sys.exit(0)

if __name__ == "__main__":
    main()

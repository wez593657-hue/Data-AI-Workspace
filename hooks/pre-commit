#!/usr/bin/env python3
import subprocess
import sys
import os

root = subprocess.run(
    ['git', 'rev-parse', '--show-toplevel'], capture_output=True, text=True, check=True
).stdout.strip()
task_id = os.environ.get('HARNESS_TASK_ID', '')
if not task_id:
    print('Harness 变更门禁失败: 必须设置 HARNESS_TASK_ID', file=sys.stderr)
    sys.exit(2)
guard = subprocess.run(
    [sys.executable, 'scripts/harness/change_guard.py', '--task-id', task_id, '--scope', 'staged'], cwd=root
)
if guard.returncode != 0:
    sys.exit(guard.returncode)
sys.exit(subprocess.run([sys.executable, 'scripts/pre_commit_hook.py', '--mode', 'full'], cwd=root).returncode)

#!/usr/bin/env python3

import sys
import os

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(BASE_DIR, 'scripts'))

from utils import fix_windows_encoding, safe_print

fix_windows_encoding()

COMMIT_MSG_FILE = sys.argv[1]

VALID_TYPES = {
    'feat', 'fix', 'docs', 'style', 'refactor', 'perf', 'test', 'chore', 'build', 'ci', 'revert'
}

MAX_SUBJECT_LENGTH = 50
MAX_BODY_LINE_LENGTH = 72

def validate_commit_message(msg):
    errors = []
    lines = msg.strip().split('\n')
    
    if not lines:
        errors.append('提交信息不能为空')
        return errors
    
    subject = lines[0]
    
    if not subject:
        errors.append('提交信息主题不能为空')
        return errors
    
    if len(subject) > MAX_SUBJECT_LENGTH:
        errors.append(f'主题长度超过{MAX_SUBJECT_LENGTH}字符（当前{len(subject)}字符）')
    
    parts = subject.split(':')
    if len(parts) >= 2:
        commit_type = parts[0].strip()
        description = ':'.join(parts[1:]).strip()
        if commit_type not in VALID_TYPES:
            errors.append(f'提交类型"{commit_type}"不合法，必须是: {", ".join(sorted(VALID_TYPES))}')
        if not description:
            errors.append('提交信息缺少描述内容')
    else:
        errors.append('提交信息格式不正确，应为: type: description')
    
    for i, line in enumerate(lines[1:], start=2):
        if line and len(line) > MAX_BODY_LINE_LENGTH:
            errors.append(f'第{i}行长度超过{MAX_BODY_LINE_LENGTH}字符')
    
    return errors

if __name__ == '__main__':
    if len(sys.argv) < 2:
        safe_print('[ERROR] commit-msg: 缺少提交信息文件参数')
        sys.exit(1)
    
    with open(COMMIT_MSG_FILE, 'r', encoding='utf-8', errors='replace') as f:
        msg = f.read()
    
    errors = validate_commit_message(msg)
    
    if errors:
        safe_print('\n[ERROR] 提交信息格式校验失败:')
        for err in errors:
            safe_print(f'  - {err}')
        safe_print('\n格式要求:')
        safe_print('  <type>: <subject>')
        safe_print('  <BLANK LINE>')
        safe_print('  <body>')
        safe_print(f'  type: {", ".join(sorted(VALID_TYPES))}')
        safe_print(f'  subject最大{MAX_SUBJECT_LENGTH}字符，body每行最大{MAX_BODY_LINE_LENGTH}字符')
        sys.exit(1)
    
    safe_print('[OK] 提交信息格式校验通过')
    sys.exit(0)

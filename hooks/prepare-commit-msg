#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import sys
import re

def main():
    print("=" * 50)
    print("  Git Prepare-Commit-Msg Hook")
    print("=" * 50)
    
    if len(sys.argv) < 2:
        print("  ✓ 跳过检查")
        sys.exit(0)
    
    commit_msg_file = sys.argv[1]
    
    try:
        with open(commit_msg_file, 'r', encoding='utf-8') as f:
            commit_msg = f.read().strip()
    except:
        print("  ✓ 无法读取提交信息文件")
        sys.exit(0)
    
    if not commit_msg:
        sys.exit(0)
    
    valid_format = r'^(feat|fix|docs|refactor|style|test|chore|sync)\(.*\): .+'
    if not re.match(valid_format, commit_msg):
        print("   ✗ 提交信息格式不正确")
        print(f"   ✗ 当前格式: {commit_msg}")
        print("   ✗ 格式要求: <type>(scope): <subject>")
        print("   ✗ 类型: feat, fix, docs, refactor, style, test, chore, sync")
        print("   ✗ 示例: feat(ddl): 新增客户风险评估表")
        sys.exit(1)
    
    print("   ✓ 提交信息格式正确")
    print("=" * 50)
    
    sys.exit(0)

if __name__ == "__main__":
    main()